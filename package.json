{
  "name": "upgrade-pilot-mcp",
  "version": "0.3.0",
  "description": "Workflow-oriented MCP server for safer JS/TS stack upgrades and migrations.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "mcp",
    "upgrade",
    "migration",
    "javascript",
    "typescript",
    "dependencies",
    "breaking-changes",
    "codemod"
  ],
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kdinisv/upgrade-pilot-mcp.git"
  },
  "bin": {
    "upgrade-pilot-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "tsx --test tests/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.7.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/semver": "^7.7.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
