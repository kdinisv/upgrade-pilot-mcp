{
  "name": "upgrade-pilot-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Workflow-oriented MCP server for safer JS/TS stack upgrades and migrations.",
  "type": "module",
  "bin": {
    "upgrade-pilot-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.7.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/semver": "^7.7.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
